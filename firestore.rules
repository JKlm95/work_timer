rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function billingRatePercentOk(data) {
      return !data.keys().hasAny(['billingRatePercent']) ||
          (data.billingRatePercent is int &&
              (data.billingRatePercent == 50 ||
                  data.billingRatePercent == 80 ||
                  data.billingRatePercent == 100 ||
                  data.billingRatePercent == 150 ||
                  data.billingRatePercent == 200));
    }

    function hasValidEntryShape(data) {
      return data.keys().hasAll(['workspaceId', 'start', 'end', 'mode', 'updatedAt', 'isDeleted']) &&
          billingRatePercentOk(data) &&
          data.workspaceId is string &&
          data.start is timestamp &&
          data.end is timestamp &&
          data.updatedAt is timestamp &&
          data.mode is string &&
          data.isDeleted is bool;
    }

    function hasValidWorkspaceShape(data) {
      return data.keys().hasAll(['name', 'createdAt', 'updatedAt', 'isArchived']) &&
          data.name is string &&
          data.createdAt is timestamp &&
          data.updatedAt is timestamp &&
          data.isArchived is bool;
    }

    // MVP: indeks email → uid dla panelu pracodawcy (Flutter Web czyta z klienta).
    // Odczyt: dowolny zalogowany użytkownik — świadomy kompromis prywatności na MVP.
    // Zapis: tylko własny uid + email zgodny z tokenem + emailLower == id dokumentu
    // (żeby nie nadpisać cudzego wpisu pod fałszywym adresem przy tym samym koncie).
    function hasValidUserEmailIndexShape(data, emailLower) {
      return data.keys().hasAll(['uid', 'email', 'emailLower', 'updatedAt', 'firstName', 'lastName']) &&
          data.uid is string &&
          data.email is string &&
          data.emailLower is string &&
          data.firstName is string &&
          data.lastName is string &&
          data.updatedAt is timestamp &&
          data.uid == request.auth.uid &&
          data.emailLower == emailLower &&
          data.email == request.auth.token.email &&
          (!data.keys().hasAny(['displayName']) || data.displayName is string) &&
          (!data.keys().hasAny(['providerIds']) || data.providerIds is list);
    }

    // Profil pracownika (imię / nazwisko) — tylko właściciel; dokument `main`.
    function hasValidUserProfileMainShape(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'displayName', 'email', 'updatedAt']) &&
          data.firstName is string &&
          data.lastName is string &&
          data.displayName is string &&
          data.email is string &&
          data.updatedAt is timestamp &&
          data.email == request.auth.token.email &&
          (data.firstName.size() > 0 || data.lastName.size() > 0);
    }

    match /users/{uid}/profile/{docId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) &&
          docId == 'main' &&
          hasValidUserProfileMainShape(request.resource.data);
      allow delete: if false;
    }

    match /userEmailIndex/{emailLower} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && hasValidUserEmailIndexShape(request.resource.data, emailLower);
      allow delete: if false;
    }

    match /users/{uid}/entries/{entryId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && hasValidEntryShape(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid}/workspaces/{workspaceId} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && hasValidWorkspaceShape(request.resource.data);
      allow delete: if false;
    }
  }
}
