<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_workspace_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_button_background"
            android:contentDescription="@string/widget_cd_prev_workspace"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_chevron_left" />

        <TextView
            android:id="@+id/widget_workspace_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/widget_title_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_workspace_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_button_background"
            android:contentDescription="@string/widget_cd_next_workspace"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_chevron_right" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_horizontal"
        android:letterSpacing="0.02"
        android:maxLines="1"
        android:text="@string/widget_status_idle"
        android:textColor="@color/widget_status_idle"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@string/widget_timer_placeholder"
        android:textColor="@color/widget_timer_text"
        android:textSize="32sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widgetPlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_button_background"
            android:contentDescription="@string/widget_cd_play"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_play" />

        <ImageButton
            android:id="@+id/widgetPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_button_background"
            android:contentDescription="@string/widget_cd_pause"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_pause" />

        <ImageButton
            android:id="@+id/widgetStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/widget_button_background_stop"
            android:contentDescription="@string/widget_cd_stop"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_stop" />
    </LinearLayout>
</LinearLayout>
